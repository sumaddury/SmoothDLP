# Compiled test binaries -- named test_<module> with no extension, matching
# test_<module>.cpp. An explicit per-binary list here previously missed
# test_lin_alg (added after the list was written, never appended) and let it
# get committed; this pattern-based exclusion covers any current or future
# one automatically instead of relying on remembering to update a list.
tests/internal/test_*
!tests/internal/test_*.cpp
!tests/internal/test_*.h
tests/internal/*.dSYM
tests/internal/*.o
notebooks/

# emacs autosave (#file#) and lock (.#file) files
# leading '#' must be escaped -- gitignore treats an unescaped one as a
# comment marker, so the unescaped form silently ignored nothing.
\#*#
.#*
